#!/usr/bin/env python3
"""
ARIMAX(1,1,1) — Monthly Grocery Price Model (Lean Spec)
Non-seasonal | Manual specification | Standardized exogenous
"""

import pandas as pd
import numpy as np
from statsmodels.tsa.arima.model import ARIMA
from statsmodels.tsa.stattools import adfuller
from statsmodels.stats.diagnostic import het_breuschpagan, acorr_ljungbox
from statsmodels.stats.stattools import jarque_bera
from statsmodels.stats.outliers_influence import variance_inflation_factor
from sklearn.preprocessing import StandardScaler
import warnings
warnings.filterwarnings("ignore")

# ─── 1. Load Data ────────────────────────────────────────────
df = pd.read_csv("population_density.csv")
df.columns = ["date", "grocery_price", "population", "unemployment_rate"]
df["date"] = pd.to_datetime(df["date"])
df = df.sort_values("date").reset_index(drop=True)
df = df.dropna(subset=["unemployment_rate"])  # drop rows with missing values

print(f"Observations: {len(df)}")
print(f"Sample period: {df['date'].min().strftime('%Y-%m')} to {df['date'].max().strftime('%Y-%m')}")
print()

# ─── 2. ADF Tests ────────────────────────────────────────────
def run_adf(series, name):
    result = adfuller(series, autolag="AIC")
    print(f"ADF Test: {name}")
    print(f"  Test Stat: {result[0]:.4f}")
    print(f"  p-value:   {result[1]:.4f}")
    print(f"  Critical:  1%={result[4]['1%']:.3f}  5%={result[4]['5%']:.3f}")
    print(f"  Stationary: {'Yes' if result[1] < 0.05 else 'No'}")
    print()
    return result[1] < 0.05

stat_gp = run_adf(df["grocery_price"], "grocery_price (levels)")
stat_ur = run_adf(df["unemployment_rate"], "unemployment_rate")
stat_pop = run_adf(df["population"], "population")

# Difference grocery_price if non-stationary
if not stat_gp:
    df["d_grocery"] = df["grocery_price"].diff()
    df = df.dropna().reset_index(drop=True)
    run_adf(df["d_grocery"], "Δ grocery_price (first diff)")
    endog = df["d_grocery"]
else:
    endog = df["grocery_price"]

# ─── 3. Standardize Exogenous ────────────────────────────────
scaler = StandardScaler()
exog_raw = df[["unemployment_rate", "population"]]
exog = pd.DataFrame(
    scaler.fit_transform(exog_raw),
    columns=["unemployment_rate_std", "population_std"],
    index=df.index,
)

# ─── 4. VIF ──────────────────────────────────────────────────
print("Variance Inflation Factors:")
for i, col in enumerate(exog.columns):
    vif = variance_inflation_factor(exog.values, i)
    print(f"  {col}: {vif:.2f}")
print()

# ─── 5. Train/Test Split ─────────────────────────────────────
train_size = int(len(endog) * 0.80)
endog_train = endog.iloc[:train_size]
exog_train = exog.iloc[:train_size]
endog_test = endog.iloc[train_size:]
exog_test = exog.iloc[train_size:]

print(f"Train: {train_size}  |  Test: {len(endog) - train_size}")
print()

# ─── 6. Fit ARIMA(1,1,0) on differenced series ──────────────
#   Since we already differenced, we use d=0 in ARIMA on d_grocery
#   ARIMA(1,0,1) on d_grocery ≡ ARIMA(1,1,1) on grocery_price
model = ARIMA(endog_train, exog=exog_train, order=(1, 0, 1), trend="c")
results = model.fit()
print(results.summary())
print()

# ─── 7. Residual Diagnostics ─────────────────────────────────
resid = results.resid

# Ljung-Box
lb = acorr_ljungbox(resid, lags=[10], return_df=True)
print(f"Ljung-Box (lag=10): stat={lb['lb_stat'].values[0]:.3f}  p={lb['lb_pvalue'].values[0]:.4f}")

# Jarque-Bera
jb_stat, jb_p, skew, kurt = jarque_bera(resid)
print(f"Jarque-Bera: stat={jb_stat:.3f}  p={jb_p:.4f}")

# Breusch-Pagan
exog_with_const = np.column_stack([np.ones(len(exog_train)), exog_train.values])
bp_stat, bp_p, _, _ = het_breuschpagan(resid, exog_with_const)
print(f"Breusch-Pagan: stat={bp_stat:.3f}  p={bp_p:.4f}")
print()

# ─── 8. Out-of-sample Forecast ───────────────────────────────
forecast = results.get_forecast(steps=len(endog_test), exog=exog_test)
pred = forecast.predicted_mean
ci = forecast.conf_int(alpha=0.05)

# MAPE
actual_prices = df["grocery_price"].iloc[train_size:].values
# Reconstruct predicted levels from differenced predictions
base = df["grocery_price"].iloc[train_size - 1]
pred_levels = base + pred.cumsum()
mape = np.mean(np.abs((actual_prices - pred_levels.values) / actual_prices)) * 100
print(f"MAPE (test set): {mape:.2f}%")
print(f"AIC: {results.aic:.2f}")
print(f"BIC: {results.bic:.2f}")
print()

# ─── 9. Coefficient Interpretation ───────────────────────────
unemp_coef = results.params["unemployment_rate_std"]
unemp_pval = results.pvalues["unemployment_rate_std"]
print("=" * 60)
print("KEY FINDING: Unemployment → Grocery Prices")
print(f"  Coefficient (std): {unemp_coef:.2f}")
print(f"  p-value:           {unemp_pval:.4f}")
print(f"  Sign:              {'Negative (inverse)' if unemp_coef < 0 else 'Positive'}")
print(f"  Significant:       {'Yes' if unemp_pval < 0.05 else 'No'}")
print()
if unemp_coef < 0 and unemp_pval < 0.05:
    print("CONCLUSION: The data SUPPORTS an inverse relationship between")
    print("unemployment and grocery prices at the U.S. national level.")
else:
    print("CONCLUSION: The data does NOT support a statistically significant")
    print("inverse relationship at the 5% level.")
print("=" * 60)
